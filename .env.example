# FBC Ops Center — Environment Variables
# Copy this file to .env and fill in the values.
# In Replit, add these as Secrets (Tools → Secrets).

# === QuickBooks Online ===
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REFRESH_TOKEN=
QBO_REALM_ID=
# QBO_SANDBOX=true  # Uncomment for sandbox/testing

# === Twilio ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# === Helcim (set once account is created) ===
HELCIM_API_TOKEN=
